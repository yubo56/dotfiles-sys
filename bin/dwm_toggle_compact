#     xmodmap -e 'keycode 41 = u U grave asciitilde'
# else
#     xmodmap -e 'keycode 9 = grave asciitilde grave asciitilde'
#     xmodmap -e 'keycode 49 = Escape Escape'
#     xmodmap -e 'keycode 41 = u U Escape'
# fi
xset r rate 150 60
