#! /bin/bash

# on 60% keeb, need to run this at start
if xkbcomp "$DISPLAY" -xkb - | grep 'key.*<ESC>.*grave'; then
    xkbcomp -I"$HOME/.xkb" "$HOME/.xkb/keymap/dvorak_caps_nav" "$DISPLAY" 2> /dev/null
else
    xkbcomp -I"$HOME/.xkb" "$HOME/.xkb/keymap/dvorak_caps_nav_grave" "$DISPLAY" 2> /dev/null
fi
