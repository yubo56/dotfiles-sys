'''
GPT-5.5 generated script that will hook into firefox addon so that pdf files are
forcibly downloaded and opened using local reader (xdg-open)
'''
#!/usr/bin/env python3
import json
import os
import pathlib
import struct
import subprocess
import sys


DEFAULT_ALLOWED_DIR = pathlib.Path.home() / "Downloads" / "firefoxpdfs"


def read_message():
    raw_length = sys.stdin.buffer.read(4)
    if not raw_length:
        return None
    if len(raw_length) != 4:
        raise ValueError("Incomplete message length prefix")

    message_length = struct.unpack("@I", raw_length)[0]
    raw_message = sys.stdin.buffer.read(message_length)
    if len(raw_message) != message_length:
        raise ValueError("Incomplete message body")

    return json.loads(raw_message.decode("utf-8"))


def send_message(message):
    raw_message = json.dumps(message, separators=(",", ":")).encode("utf-8")
    sys.stdout.buffer.write(struct.pack("@I", len(raw_message)))
    sys.stdout.buffer.write(raw_message)
    sys.stdout.buffer.flush()


def resolve_allowed_dir():
    configured = os.environ.get("FIREFOX_OPENPDF_ALLOWED_DIR")
    if configured:
        return pathlib.Path(configured).expanduser().resolve()
    return DEFAULT_ALLOWED_DIR.resolve()


def validate_pdf_path(raw_path, allowed_dir):
    if not isinstance(raw_path, str) or not raw_path:
        raise ValueError("Missing PDF path")

    pdf_path = pathlib.Path(raw_path).expanduser().resolve()

    if pdf_path.suffix.lower() != ".pdf":
        raise ValueError("Refusing to open a non-PDF file")

    if not pdf_path.is_file():
        raise ValueError("PDF path does not exist or is not a file")

    try:
        pdf_path.relative_to(allowed_dir)
    except ValueError as exc:
        raise ValueError(f"PDF path must be inside {allowed_dir}") from exc

    return pdf_path


def open_pdf(pdf_path):
    subprocess.Popen(
        ["zathura", str(pdf_path)],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def handle_message(message):
    allowed_dir = resolve_allowed_dir()
    pdf_path = validate_pdf_path(message.get("path"), allowed_dir)
    open_pdf(pdf_path)
    return {"ok": True, "opened": str(pdf_path)}


def main():
    while True:
        try:
            message = read_message()
            if message is None:
                return
            send_message(handle_message(message))
        except Exception as exc:
            print(f"firefox_openpdf: {exc}", file=sys.stderr)
            send_message({"ok": False, "error": str(exc)})


if __name__ == "__main__":
    main()
